---
import Logo from './Logo.astro';
import { Icon } from 'astro-icon/components';

const navLinks = [
  { href: '/#proyectos', label: 'Proyectos', section: 'proyectos' },
  { href: '/bigdeals', label: 'BigDeals', section: 'bigdeals', icon: 'lucide:briefcase' },
  { href: '/#sobre-mi', label: 'Sobre mí', section: 'sobre-mi' },
  { href: '/#stack', label: 'Stack', section: 'stack' },
  { href: '/#proceso', label: 'Proceso', section: 'proceso' }
];
---
<header class="sticky top-0 z-40 transition-all" id="navbar">
  <div class="container flex items-center justify-between py-4">
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition" transition:name="logo" aria-label="Inicio">
      <Logo size={32} variant="horizontal" />
    </a>

    <nav aria-label="Principal" class="hidden md:flex items-center gap-7 text-sm font-medium">
      {navLinks.map((l) => (
        <a href={l.href} data-nav-link={l.section} class="nav-link relative inline-flex items-center gap-1.5 py-1 transition-colors hover:text-cp-accent">
          {l.icon && <Icon name={l.icon} class="w-4 h-4" />}
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <button id="theme-toggle" aria-label="Alternar tema" class="p-2 rounded-lg hover:bg-cp-surface transition focus-visible:outline-2 focus-visible:outline-cp-accent focus-visible:outline-offset-2">
        <Icon name="lucide:sun" class="w-5 h-5 hidden light:inline" />
        <Icon name="lucide:moon" class="w-5 h-5 light:hidden" />
      </button>
      <a href="/#contacto" class="magnetic-btn hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-cp-accent text-white text-sm font-semibold hover:opacity-90 transition focus-visible:outline-2 focus-visible:outline-cp-gold focus-visible:outline-offset-2">
        Contacto <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    height: 2px;
    width: 100%;
    background: linear-gradient(90deg, var(--cp-accent), var(--cp-gold));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .nav-link:hover::after,
  .nav-link[data-active="true"]::after {
    transform: scaleX(1);
  }

  #navbar.glass {
    background: color-mix(in oklab, var(--cp-bg) 75%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid var(--cp-border);
  }
</style>
