---
import KanbanDemo from './demos/KanbanDemo.astro';
import VideoGenDemo from './demos/VideoGenDemo.astro';
import MarkowitzDemo from './demos/MarkowitzDemo.astro';

interface Props {
  videoUrl?: string;
  animationKey?: 'kanban' | 'video-gen' | 'markowitz';
  poster?: string;
  title: string;
}
const { videoUrl, animationKey, poster, title } = Astro.props;

// Derive caption track URL from videoUrl (e.g. /videos/x.mp4 -> /videos/captions/x.vtt)
const captionsUrl = videoUrl
  ? videoUrl.replace(/^\/videos\/([^/]+)\.mp4$/, '/videos/captions/$1.vtt')
  : null;
---
{videoUrl && (
  <figure class="mt-10 rounded-3xl overflow-hidden border border-cp-border bg-cp-surface">
    <video
      controls
      preload="metadata"
      playsinline
      poster={poster}
      class="w-full h-auto block bg-black"
      aria-label={`Demo en video: ${title}`}
    >
      <source src={videoUrl} type="video/mp4" />
      {captionsUrl && (
        <track
          default
          kind="captions"
          srclang="es"
          label="Español"
          src={captionsUrl}
        />
      )}
      Tu navegador no soporta video HTML5.
    </video>
    <figcaption class="px-5 py-3 text-xs text-cp-muted flex items-center gap-2">
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-cp-accent"></span>
      Demo grabada · {title}
    </figcaption>
  </figure>
)}

{!videoUrl && animationKey === 'kanban' && (
  <div class="mt-10">
    <KanbanDemo />
    <p class="mt-3 text-xs text-cp-muted text-center">Vista en vivo del refresh nocturno (animación)</p>
  </div>
)}

{!videoUrl && animationKey === 'video-gen' && (
  <div class="mt-10">
    <VideoGenDemo />
    <p class="mt-3 text-xs text-cp-muted text-center">Pipeline en 4 etapas: Markdown → Frames → Voz → MP4</p>
  </div>
)}

{!videoUrl && animationKey === 'markowitz' && (
  <div class="mt-10">
    <MarkowitzDemo />
    <p class="mt-3 text-xs text-cp-muted text-center">12 preguntas → frontera eficiente trazada en vivo</p>
  </div>
)}
