---
const stats = [
  { value: '4 días', label: 'De idea a demo productiva', sub: 'Promedio para un build completo end-to-end con datos seedeados.' },
  { value: '0 código', label: 'Manual sin asistencia', sub: 'Toda la metadata, Apex y LWC nacen de Claude Code más arquitectura humana.' },
  { value: '8+ demos', label: 'Productivas en SDOs activas', sub: 'AXA, BBVA Wealth, BBVA PYMES, Previsora y más, todas vivas y demoables.' }
];
---
<section id="sobre-mi" class="relative py-32 border-t border-cp-border">
  <div class="container">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Avatar SVG geométrico -->
      <div class="reveal flex justify-center lg:justify-start">
        <div class="relative" style="width: min(400px, 100%); aspect-ratio: 1;">
          <svg viewBox="0 0 400 400" class="w-full h-full" role="img" aria-label="Avatar geométrico de Camilo Páez">
            <defs>
              <linearGradient id="cp-avatar-grad" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#0070D2"/>
                <stop offset="100%" stop-color="#EF9F27"/>
              </linearGradient>
              <linearGradient id="cp-avatar-grad2" x1="1" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#1A4DA0"/>
                <stop offset="100%" stop-color="#0070D2"/>
              </linearGradient>
              <filter id="cp-avatar-glow" x="-30%" y="-30%" width="160%" height="160%">
                <feGaussianBlur stdDeviation="14" result="blur"/>
                <feMerge>
                  <feMergeNode in="blur"/>
                  <feMergeNode in="SourceGraphic"/>
                </feMerge>
              </filter>
            </defs>

            <!-- Decorative outer rings -->
            <circle cx="200" cy="200" r="190" fill="none" stroke="url(#cp-avatar-grad)" stroke-width="0.5" opacity="0.35"/>
            <circle cx="200" cy="200" r="170" fill="none" stroke="url(#cp-avatar-grad)" stroke-width="0.5" opacity="0.5" stroke-dasharray="2 6"/>

            <!-- Decorative geometric shapes orbiting -->
            <g opacity="0.85">
              <rect x="20" y="80" width="40" height="40" rx="6" fill="none" stroke="#EF9F27" stroke-width="1.5" transform="rotate(15 40 100)"/>
              <polygon points="350,60 380,100 320,100" fill="none" stroke="#0070D2" stroke-width="1.5"/>
              <circle cx="360" cy="280" r="14" fill="none" stroke="#EF9F27" stroke-width="1.5"/>
              <circle cx="60" cy="320" r="6" fill="#0070D2"/>
              <line x1="20" y1="200" x2="60" y2="200" stroke="#EF9F27" stroke-width="2"/>
              <line x1="340" y1="200" x2="380" y2="200" stroke="#0070D2" stroke-width="2"/>
            </g>

            <!-- Hexagon background -->
            <polygon points="200,40 340,120 340,280 200,360 60,280 60,120"
                     fill="url(#cp-avatar-grad2)" opacity="0.08"/>
            <polygon points="200,40 340,120 340,280 200,360 60,280 60,120"
                     fill="none" stroke="url(#cp-avatar-grad)" stroke-width="1" opacity="0.6"/>

            <!-- Inner radial gradient circle -->
            <circle cx="200" cy="200" r="120" fill="url(#cp-avatar-grad)" opacity="0.15" filter="url(#cp-avatar-glow)"/>

            <!-- Diamond accents -->
            <polygon points="200,90 230,200 200,310 170,200" fill="none" stroke="url(#cp-avatar-grad)" stroke-width="0.8" opacity="0.5"/>

            <!-- Initials CP -->
            <text x="200" y="240" text-anchor="middle"
                  font-family="Inter Variable, sans-serif"
                  font-weight="800"
                  font-size="150"
                  letter-spacing="-8"
                  fill="url(#cp-avatar-grad)">CP</text>

            <!-- Gold dot accent -->
            <circle cx="278" cy="118" r="6" fill="#EF9F27"/>
            <circle cx="278" cy="118" r="12" fill="none" stroke="#EF9F27" stroke-width="1" opacity="0.5"/>
          </svg>
        </div>
      </div>

      <!-- Right column -->
      <div class="reveal-stagger">
        <div class="text-cp-accent text-sm font-semibold tracking-widest uppercase">Sobre mí</div>
        <h2 class="mt-3">Construyo demos. Cuento historias.</h2>

        <p class="mt-6 text-cp-muted leading-relaxed text-[17px]">
          Soy Solutions Engineer en Salesforce Colombia. Mi día a día es traducir necesidades de negocio complejas en demos que convencen comités directivos: Financial Services Cloud, Health Cloud, Agentforce, portales LWR, integraciones reales.
        </p>
        <p class="mt-4 text-cp-muted leading-relaxed text-[17px]">
          Uso Claude Code como co-piloto de arquitectura: pair-programming sobre metadata, Apex, LWC y agentes. La velocidad ya no es un cuello de botella; el cuello de botella ahora es la calidad de la pregunta.
        </p>

        <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-5">
          {stats.map((s) => (
            <div class="rounded-2xl border border-cp-border bg-cp-surface/40 p-5 hover:border-cp-accent transition-colors">
              <div class="text-3xl font-extrabold gradient-text">{s.value}</div>
              <div class="mt-1.5 text-sm font-semibold text-cp-text">{s.label}</div>
              <p class="mt-1.5 text-xs text-cp-muted leading-relaxed">{s.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
