---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  icon: string;
  class?: string;
}
const { name, icon, class: cls = '' } = Astro.props;
---
<span class:list={["tech-badge inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md border border-cp-border bg-cp-bg/60 font-mono text-[11px] tracking-tight text-cp-text/85 hover:border-cp-accent hover:text-cp-accent transition-colors", cls]}>
  <Icon name={icon} class="w-3 h-3 shrink-0" aria-hidden="true" />
  <span>{name}</span>
</span>
