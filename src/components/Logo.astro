---
interface Props {
  size?: number;
  variant?: 'horizontal' | 'square' | 'mark';
  class?: string;
}
const { size = 32, variant = 'horizontal', class: cls = '' } = Astro.props;
---
{variant === 'horizontal' && (
  <svg class={cls} width={size * 4} height={size} viewBox="0 0 160 40" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true">
    <defs>
      <linearGradient id="cp-grad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0070D2"/>
        <stop offset="100%" stop-color="#1A4DA0"/>
      </linearGradient>
    </defs>
    <text x="0" y="29" font-family="Inter Variable, sans-serif" font-weight="800" font-size="28" letter-spacing="-1.5" fill="url(#cp-grad)">CP</text>
    <line x1="44" y1="10" x2="44" y2="32" stroke="#EF9F27" stroke-width="1.5" opacity="0.7"/>
    <text x="52" y="20" font-family="Inter Variable, sans-serif" font-weight="600" font-size="11" fill="currentColor" letter-spacing="0.5">SALESFORCE</text>
    <text x="52" y="34" font-family="Inter Variable, sans-serif" font-weight="400" font-size="10" fill="currentColor" opacity="0.65" letter-spacing="2">SOLUTIONS ENG.</text>
    <circle cx="148" cy="20" r="3" fill="#EF9F27"/>
  </svg>
)}
{variant === 'square' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="CP">
    <defs>
      <linearGradient id="cp-sq" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#0070D2"/>
        <stop offset="100%" stop-color="#1A4DA0"/>
      </linearGradient>
    </defs>
    <rect width="64" height="64" rx="14" fill="url(#cp-sq)"/>
    <text x="32" y="44" text-anchor="middle" font-family="Inter Variable, sans-serif" font-weight="800" font-size="32" letter-spacing="-1" fill="#fff">CP</text>
    <circle cx="50" cy="14" r="3" fill="#EF9F27"/>
  </svg>
)}
{variant === 'mark' && (
  <svg class={cls} width={size} height={size} viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="CP mark">
    <text x="0" y="29" font-family="Inter Variable, sans-serif" font-weight="800" font-size="28" letter-spacing="-1.5" fill="currentColor">CP</text>
    <circle cx="36" cy="8" r="3" fill="#EF9F27"/>
  </svg>
)}
