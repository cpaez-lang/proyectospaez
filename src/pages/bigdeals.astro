---
import Layout from '../layouts/Layout.astro';
import DealNav from '../components/DealNav.astro';
import { Icon } from 'astro-icon/components';
import '../styles/bigdeals.css';

const deals = [
  {
    href: '/bigdeals/bbva-colombia',
    name: 'BBVA Colombia',
    tagline: 'El primer banco agéntico de Colombia — y el blueprint para todo el Grupo BBVA en Latam.',
    tagIcon: 'lucide:landmark',
    tagLabel: 'FSI · Banca · FY27',
    meta: [
      { label: 'ACV', value: '~$1.05M' },
      { label: 'ROI Y3', value: '+268%' },
      { label: 'Sector', value: 'Banca' }
    ]
  },
  {
    href: '/bigdeals/la-previsora',
    name: 'La Previsora S.A.',
    tagline: 'La primera aseguradora pública de Colombia con IA integrada al core del negocio.',
    tagIcon: 'lucide:shield',
    tagLabel: 'Sector Público · Seguros',
    meta: [
      { label: 'ACV', value: '$766K' },
      { label: 'Target', value: '$1M' },
      { label: 'Sector', value: 'Asegurador' }
    ]
  }
];
---
<Layout
  title="BigDeals — Camilo Páez"
  description="Business cases ejecutivos de los deals estratégicos en construcción. BBVA Colombia · La Previsora."
>
  <DealNav current="index" />

  <section class="bd-hero relative overflow-hidden">
    <div class="absolute inset-0 -z-10" aria-hidden="true">
      <div class="absolute inset-0" style="background:radial-gradient(ellipse 80% 50% at 50% 0%, rgba(59,130,246,0.18), transparent 60%);"></div>
      <svg class="absolute inset-0 w-full h-full opacity-[0.04]" aria-hidden="true">
        <pattern id="bd-grid-idx" width="48" height="48" patternUnits="userSpaceOnUse">
          <path d="M48 0H0V48" fill="none" stroke="currentColor" stroke-width="0.5"/>
        </pattern>
        <rect width="100%" height="100%" fill="url(#bd-grid-idx)"/>
      </svg>
    </div>

    <div class="container pt-12 pb-16">
      <div class="bd-tag inline-flex items-center gap-2 px-3 py-1.5 rounded-full border text-[11px] font-bold uppercase tracking-[0.18em] mb-8" style="border-color: rgba(59,130,246,0.4); background: rgba(59,130,246,0.08); color: #93C5FD;">
        <Icon name="lucide:briefcase" class="w-3.5 h-3.5" />
        Business cases ejecutivos
      </div>

      <h1 class="bd-title">BigDeals</h1>
      <p class="bd-subtitle">
        Casos ejecutivos de los deals estratégicos en construcción. Fundamentos validados,
        ROI consolidado, riesgos mapeados — listos para una sesión con C-Suite.
      </p>

      <div class="bd-deal-grid mt-14">
        {deals.map((d) => (
          <a class="bd-deal-card" href={d.href}>
            <span class="bd-deal-card-tag">
              <Icon name={d.tagIcon} class="w-3.5 h-3.5" />
              {d.tagLabel}
            </span>
            <h2 class="bd-deal-card-name">{d.name}</h2>
            <p class="bd-deal-card-tagline">{d.tagline}</p>
            <div class="bd-deal-card-meta">
              {d.meta.map((m) => (
                <div>
                  <strong>{m.value}</strong>
                  <span>{m.label}</span>
                </div>
              ))}
            </div>
            <span class="bd-deal-card-cta">Abrir business case</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bd-meta">
    <div class="container py-12">
      <div class="bd-meta-line"></div>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <div class="text-xs uppercase tracking-[0.2em] text-cp-muted mb-2">Preparado por</div>
          <div class="font-bold">Camilo Páez</div>
          <div class="text-cp-muted">Lead SE · Salesforce Colombia</div>
        </div>
        <div class="sm:text-right">
          <div class="text-xs uppercase tracking-[0.2em] text-cp-muted mb-2">Última actualización</div>
          <div class="font-bold">FY2027 Q3</div>
          <div class="text-cp-muted">Pipeline activo · 2 deals</div>
        </div>
      </div>
    </div>
  </section>
</Layout>
