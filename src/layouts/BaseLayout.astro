---
import { ClientRouter } from 'astro:transitions';
import { SEO } from 'astro-seo';
import '@fontsource-variable/inter';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  article?: boolean;
}
const {
  title,
  description = 'Portafolio de Camilo Páez — Solutions Engineer Salesforce Colombia. Demos productivas con Claude Code.',
  ogImage = '/images/og-cover.svg',
  article = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#0C0C0E" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="manifest" href="/manifest.webmanifest" />

    <SEO
      title={title}
      description={description}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title,
          type: article ? 'article' : 'website',
          image: ogImageURL,
          url: canonicalURL
        },
        optional: { description, siteName: 'Proyectos Páez', locale: 'es_CO' }
      }}
      twitter={{ card: 'summary_large_image', title, description, image: ogImageURL }}
      extend={{
        meta: [
          { name: 'author', content: 'Camilo Páez' },
          { name: 'robots', content: 'index, follow' }
        ]
      }}
    />

    <ClientRouter />

    <script is:inline>
      (function () {
        const saved = localStorage.getItem('theme');
        const sysLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        if (saved === 'light' || (!saved && sysLight)) {
          document.documentElement.classList.add('light');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only fixed top-2 left-2 z-50 px-4 py-2 bg-cp-accent text-white rounded">
      Saltar al contenido
    </a>

    <Nav />

    <main id="main" class="pt-20">
      <slot />
    </main>

    <Footer />

    <CustomCursor />

    <script>
      const setupNavGlass = () => {
        const nav = document.getElementById('navbar');
        if (!nav) return;
        const onScroll = () => {
          if (window.scrollY > 50) nav.classList.add('glass');
          else nav.classList.remove('glass');
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      };
      document.addEventListener('astro:page-load', setupNavGlass);
    </script>
  </body>
</html>
